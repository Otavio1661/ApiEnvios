// ApiEnvios - Schema do Banco de Dados
// PostgreSQL via Prisma ORM

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// INSTÂNCIAS WHATSAPP (entidade central — uma por número/sessão de provider)
// ─────────────────────────────────────────────
model Instance {
  id          String   @id @default(cuid())
  name        String?                       // nome amigável (apelido), único por tenant — ex: "Vendas-SP"
  slug        String?  @unique              // slug único GLOBAL para uso na URL/API — ex: "vendas-sp"
  phone       String?                       // ex: "5544999990000" — null até conectar via QR
  label       String?                       // ex: "Número Principal Gazin"
  provider    Provider                      // EVOLUTION | WAHA | CLOUD_API
  instanceId  String?                       // ID da instância no provider
  status      NumberStatus @default(ACTIVE)
  priority    Int          @default(0)      // menor = maior prioridade no fallback

  // Token de envio (estilo UltraMsg)
  token       String   @unique @default(cuid())

  // Estado de conexão (autenticação/QR — separado do ciclo de vida em `status`)
  connectionState InstanceConnState @default(DISCONNECTED)
  qrCode          String?
  qrExpiresAt     DateTime?

  // Vínculo com o tenant dono da instância
  apiClientId String
  apiClient   ApiClient @relation(fields: [apiClientId], references: [id])

  // Métricas anti-ban
  sentToday      Int       @default(0)
  sentTotal      Int       @default(0)
  lastSentAt     DateTime?
  lastResetAt    DateTime  @default(now())  // reset do contador diário

  // Ban tracking
  bannedAt       DateTime?
  banReason      String?
  bannedCount    Int       @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messages    Message[]
  rotations   NumberRotation[]
  numbers     InstanceNumber[]   // Fase C1: pool de números filhos (aditivo; lógica ainda usa os campos acima)

  @@unique([apiClientId, phone])
  @@unique([apiClientId, name])           // apelido único por tenant (NULLs distintos no Postgres)
  @@index([status, priority])
  @@index([provider])
  @@index([apiClientId, status])
}

// ─────────────────────────────────────────────
// NÚMEROS DA INSTÂNCIA (Fase C1 — Instância como pool de números)
// Cada InstanceNumber é um número/sessão de provider sob uma Instance.
// ADITIVO: nesta fase os campos espelham os da Instance; o roteamento/QR/envio
// continua usando a Instance. C2/C3/C4 movem a lógica e removem os legados.
// ─────────────────────────────────────────────
model InstanceNumber {
  id         String   @id @default(cuid())

  instanceId String
  instance   Instance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  provider           Provider
  providerInstanceId String?               // ID da sessão no provider (= Instance.instanceId)
  phone              String?
  label              String?
  status             NumberStatus      @default(ACTIVE)
  priority           Int               @default(0)

  // Estado de conexão (autenticação/QR)
  connectionState InstanceConnState @default(DISCONNECTED)
  qrCode          String?
  qrExpiresAt     DateTime?

  // Métricas anti-ban
  sentToday   Int       @default(0)
  sentTotal   Int       @default(0)
  lastSentAt  DateTime?
  lastResetAt DateTime  @default(now())

  // Ban tracking
  bannedAt    DateTime?
  banReason   String?
  bannedCount Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([instanceId, phone])
  @@index([instanceId])
  @@index([status, priority])
}

// ─────────────────────────────────────────────
// MENSAGENS ENVIADAS
// ─────────────────────────────────────────────
model Message {
  id              String        @id @default(cuid())
  externalId      String?                // ID gerado pelo sistema cliente (idempotência por tenant)

  // Tenant dono da mensagem
  apiClientId     String
  apiClient       ApiClient     @relation(fields: [apiClientId], references: [id])

  // Destinatário
  toPhone         String                 // ex: "5544988880000"

  // Conteúdo
  type            MessageType   @default(TEXT)
  content         String                 // texto ou URL da mídia
  caption         String?                // legenda para mídias

  // Roteamento
  providerId      String?                // ID no provider (ex: message id do Evolution)
  instanceId      String?
  instance        Instance?     @relation(fields: [instanceId], references: [id])
  provider        Provider?
  providerAttempt Int           @default(1)  // qual tentativa (1=evolution, 2=waha, 3=cloud)

  // Status
  status          MessageStatus @default(QUEUED)
  errorMessage    String?
  retryCount      Int           @default(0)
  maxRetries      Int           @default(3)

  // Timestamps
  scheduledAt     DateTime?              // para envio agendado
  sentAt          DateTime?
  deliveredAt     DateTime?
  readAt          DateTime?
  failedAt        DateTime?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  attempts        MessageAttempt[]

  @@unique([apiClientId, externalId])
  @@index([status])
  @@index([toPhone])
  @@index([createdAt])
  @@index([scheduledAt])
  @@index([apiClientId, createdAt])
}

// ─────────────────────────────────────────────
// TENTATIVAS DE ENVIO (histórico de fallback)
// ─────────────────────────────────────────────
model MessageAttempt {
  id          String   @id @default(cuid())
  messageId   String
  message     Message  @relation(fields: [messageId], references: [id])
  
  provider    Provider
  instanceId  String?
  attempt     Int               // 1, 2, 3...
  success     Boolean
  errorCode   String?
  errorMsg    String?
  duration    Int?              // ms
  
  createdAt   DateTime @default(now())

  @@index([messageId])
}

// ─────────────────────────────────────────────
// ROTAÇÃO DE NÚMEROS
// ─────────────────────────────────────────────
model NumberRotation {
  id          String   @id @default(cuid())
  instanceId  String
  instance    Instance @relation(fields: [instanceId], references: [id])

  reason      RotationReason   // BAN | LIMIT_REACHED | MANUAL | SCHEDULED
  triggeredBy String?          // "auto" | "webhook" | userId

  createdAt   DateTime @default(now())

  @@index([instanceId])
}

// ─────────────────────────────────────────────
// CLIENTES DA API (sistemas que consomem a API)
// ─────────────────────────────────────────────
model ApiClient {
  id          String   @id @default(cuid())
  name        String
  apiKey      String   @unique @default(cuid())
  active      Boolean  @default(true)

  // Papel do tenant
  role        ClientRole @default(CLIENT)   // ADMIN | CLIENT

  // Fallback opt-in entre as instâncias do próprio tenant (+ Cloud API)
  fallbackEnabled Boolean @default(false)

  // Rate limiting por cliente
  rateLimit   Int      @default(100)    // req/min

  // Métricas
  totalSent   Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  instances   Instance[]
  messages    Message[]
  webhooks    Webhook[]
  users       User[]

  @@index([apiKey])
}

// ─────────────────────────────────────────────
// USUÁRIOS HUMANOS (login JWT — criados SOMENTE pelo admin)
// ─────────────────────────────────────────────
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  name          String?
  role          UserRole @default(OWNER)   // papel DENTRO da conta
  emailVerified Boolean  @default(false)

  // Conta (tenant) à qual o usuário pertence
  apiClientId   String
  apiClient     ApiClient @relation(fields: [apiClientId], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([apiClientId])
}

// ─────────────────────────────────────────────
// WEBHOOKS DE NOTIFICAÇÃO
// ─────────────────────────────────────────────
model Webhook {
  id          String   @id @default(cuid())
  url         String
  events      String[] // ["BAN_DETECTED", "MESSAGE_FAILED", "NUMBER_ROTATED"]
  active      Boolean  @default(true)
  secret      String?  // para validação HMAC

  // Tenant dono do webhook (null = webhook global do admin)
  apiClientId String?
  apiClient   ApiClient? @relation(fields: [apiClientId], references: [id])

  // Histórico de entregas
  lastCalledAt  DateTime?
  failCount     Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([apiClientId])
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────
enum Provider {
  EVOLUTION   // Evolution API (principal)
  WAHA        // WAHA - fallback gratuito
  CLOUD_API   // WhatsApp Cloud API oficial - fallback pago
}

enum NumberStatus {
  ACTIVE      // funcionando
  WARMING     // em warm-up (número novo, enviando menos)
  BANNED      // banido pelo WhatsApp
  SUSPENDED   // suspenso manualmente
  RETIRED     // aposentado / substituído
}

enum ClientRole {
  ADMIN       // gerencia contas e instâncias de todos
  CLIENT      // tenant comum
}

enum UserRole {
  OWNER       // dono da conta
  MEMBER      // membro convidado da conta
}

enum InstanceConnState {
  DISCONNECTED  // sem sessão ativa
  QR_PENDING    // aguardando leitura do QR
  CONNECTED     // sessão autenticada
  BANNED        // sessão banida pelo WhatsApp
}

enum MessageStatus {
  QUEUED      // na fila
  SENDING     // sendo enviado
  SENT        // enviado ao provider
  DELIVERED   // entregue ao destinatário
  READ        // lido
  FAILED      // falhou em todos os providers
  SCHEDULED   // agendado para envio futuro
  CANCELLED   // cancelado
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  STICKER
}

enum RotationReason {
  BAN
  LIMIT_REACHED
  MANUAL
  SCHEDULED
  ERROR_RATE
}
