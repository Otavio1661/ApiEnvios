# ============================================================
# ApiEnvios - Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================================

# --- APP ---
NODE_ENV=development
PORT=3000
API_SECRET=troque-por-um-secret-forte-aqui

# --- BANCO DE DADOS ---
DATABASE_URL="postgresql://apienvios:senha123@localhost:5432/apienvios"

# --- REDIS (filas e cache) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- EVOLUTION API (Provider 1 - Principal) ---
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua-chave-aqui

# --- WAHA (Provider 2 - Fallback gratuito) ---
WAHA_URL=http://localhost:3001
WAHA_API_KEY=

# --- WHATSAPP CLOUD API OFICIAL (Provider 3 - Fallback pago) ---
WA_CLOUD_TOKEN=
WA_CLOUD_PHONE_NUMBER_ID=
WA_CLOUD_BUSINESS_ACCOUNT_ID=

# --- NOTIFICAÇÕES DE BAN ---
# Webhook que será chamado quando um número for banido
BAN_WEBHOOK_URL=
# Email para alertas (opcional)
ALERT_EMAIL=

# --- CONFIGURAÇÕES DE ENVIO ---
# Delay mínimo entre mensagens em ms (anti-ban)
SEND_DELAY_MIN=2000
# Delay máximo entre mensagens em ms (anti-ban)
SEND_DELAY_MAX=5000
# Máximo de mensagens por número por dia antes de rotacionar
MAX_MESSAGES_PER_NUMBER_DAY=200
