    "@fastify/view": "^9.1.0",
    "@prisma/client": "^5.22.0",
    "@types/bcryptjs": "^2.4.6",
    "axios": "^1.7.7",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.17.0",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.5",
    "eta": "^4.6.0",
    "fastify": "^4.28.1",
    "ioredis": "^5.4.1",
